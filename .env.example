# Vercel / Upstash Redis REST
# Có thể dùng biến do Vercel Redis/KV tự tạo:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Hoặc dùng trực tiếp biến của Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Khuyến nghị đặt một chuỗi bí mật bất kỳ để hash PIN ổn định và riêng tư hơn
SHARE_PIN_SALT=change-this-random-string
